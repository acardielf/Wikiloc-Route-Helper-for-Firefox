{
  "manifest_version": 3,
  "name": "Wikiloc Route Helper",
  "version": "0.1.0",
  "description": "Mejora la visualización de rutas en Wikiloc mediante ajustes locales de la interfaz. No afiliada a Wikiloc.",
  "homepage_url": "https://github.com/acardielf/Wikiloc-Route-Helper-for-Firefox",
  "author": "Ángel Cardiel",

  "browser_specific_settings": {
    "gecko": {
      "id": "wikiloc-route-helper@acardielf.github.io",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },

  "permissions": ["storage"],

  "action": {
    "default_title": "Wikiloc Route Helper (clic para activar/desactivar)",
    "default_icon": "icons/icon.svg"
  },

  "background": {
    "scripts": ["src/background.js"]
  },

  "content_scripts": [
    {
      "matches": ["*://*.wikiloc.com/*"],
      "js": ["src/content/wikiloc.js"],
      "css": ["src/content/wikiloc.css"],
      "run_at": "document_idle"
    }
  ]
}
